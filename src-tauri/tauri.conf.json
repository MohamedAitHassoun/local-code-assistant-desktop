{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Code Assistant",
  "version": "0.1.0",
  "identifier": "com.localcodeassistant.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Local Code Assistant",
        "label": "main",
        "width": 1500,
        "height": 950,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "app"],
    "icon": ["icons/icon.ico", "icons/icon.icns", "icons/icon.png"],
    "category": "DeveloperTool"
  }
}
